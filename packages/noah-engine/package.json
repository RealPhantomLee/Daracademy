{
  "name": "@daracademy/noah-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && npm run add-directives",
    "add-directives": "node -e \"const fs=require('fs');const files=['dist/context.js'];files.forEach(f=>{let content=fs.readFileSync(f,'utf8');if(!content.startsWith('\\\"use client\\\"')){content='\\\"use client\\\";\\n\\n'+content;fs.writeFileSync(f,content)}})\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "xstate": "^5.0.0",
    "@xstate/react": "^5.0.0",
    "framer-motion": "^12.40.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/node": "^20"
  }
}
